# Environment Variables - AutoLinks
# Copie para .env.local (git-ignored) e preencha os valores reais.

# ─── API self-hosted (obrigatório) ───────────────────────────────────────────
# Local dev: aponte para o serviço API Node.js
# Coolify/docker-compose: se o frontend for servido pelo mesmo compose, deixe em branco e use o proxy do Nginx,
#   ou coloque a URL pública do serviço api (ex.: https://api.seudominio.com)
VITE_API_URL=http://127.0.0.1:3116
APP_PUBLIC_URL=http://127.0.0.1:5173
API_PUBLIC_URL=http://127.0.0.1:3116
# Runtime de automações no navegador: mantenha desligado em produção quando o
# scheduler backend estiver ativo. Ative apenas como fallback controlado.
VITE_BROWSER_RUNTIME_ENABLED=false

# ─── Banco Supabase PostgreSQL (usado por local + deploy) ────────────────────
# Use a connection string direta do projeto Supabase.
# Exemplo: postgresql://postgres:[SUA-SENHA]@db.<project-ref>.supabase.co:5432/postgres
DATABASE_URL=postgresql://postgres:[SUA-SENHA]@db.rwurwyuhxvlnykosfkdj.supabase.co:5432/postgres
DB_SSL=true
DB_SSL_REJECT_UNAUTHORIZED=false

# Opcional para integrações futuras front-end direto com Supabase
VITE_SUPABASE_URL=https://rwurwyuhxvlnykosfkdj.supabase.co
VITE_SUPABASE_PUBLISHABLE_DEFAULT_KEY=sb_publishable_xxxxxxxxxxxxxxxxxxxxxxxxx

# ─── JWT e tokens de serviço (usados pelo serviço api) ───────────────────────
# JWT_SECRET deve ter pelo menos 32 caracteres aleatórios (OBRIGATÓRIO em produção)
JWT_SECRET=troque-por-segredo-jwt-com-32-caracteres-minimo
# JWT_EXPIRES_IN controla o tempo de vida do token (default: 2h)
JWT_EXPIRES_IN=2h
# SERVICE_TOKEN é usado pelo scheduler para autenticar como serviço (sem usuário)
SERVICE_TOKEN=troque-por-token-do-scheduler
# CREDENTIAL_ENCRYPTION_KEY: chave AES-256 para criptografar secrets no banco (OBRIGATÓRIO em produção)
# Gere com: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
CREDENTIAL_ENCRYPTION_KEY=troque-por-chave-hex-64-caracteres

# ─── E-mail transacional (Resend) ────────────────────────────────────────────
RESEND_API_KEY=troque-por-chave-re_xxxxxxxxx
RESEND_FROM=Auto Links <suporte@autolinks.pro>
# Opcional (respostas para outro e-mail):
RESEND_REPLY_TO=suporte@autolinks.pro
EMAIL_VERIFY_TOKEN_TTL_MINUTES=1440
PASSWORD_RESET_TOKEN_TTL_MINUTES=30

# ─── Microserviços ────────────────────────────────────────────────────────────
# Local: use 127.0.0.1 | Coolify: use os nomes dos serviços do docker-compose
VITE_WHATSAPP_MICROSERVICE_URL=http://127.0.0.1:3111
VITE_TELEGRAM_MICROSERVICE_URL=http://127.0.0.1:3112
VITE_SHOPEE_MICROSERVICE_URL=http://127.0.0.1:3113
VITE_MELI_RPA_URL=http://127.0.0.1:3114
VITE_OPS_CONTROL_URL=http://127.0.0.1:3115

# Opcional em desenvolvimento local (se usar token no Ops Control):
# VITE_OPS_CONTROL_TOKEN=dev-ops-token

# =========================
# CONTAS SEED
# Admin criado no primeiro boot da API (banco vazio).
# ADMIN_EMAIL e ADMIN_PASSWORD são obrigatórios em produção.
# Em dev, fallback: admin@localhost.local / senha gerada aleatoriamente.
# =========================
ADMIN_EMAIL=admin@seudominio.com
ADMIN_PASSWORD=troque-esta-senha-segura
# VITE_DEMO_ADMIN_EMAIL=admin@demo.autolinks.local
# VITE_DEMO_ADMIN_PASSWORD=demo-admin-change-me
# VITE_DEMO_USER_EMAIL=usuario@demo.autolinks.local
# VITE_DEMO_USER_PASSWORD=demo-user-change-me

# Segredos e credenciais sensiveis devem ser configurados apenas nos servicos:
# - services/whatsapp-baileys/.env
# - services/telegram-telegraph/.env
# - services/shopee-affiliate/.env
# - services/mercadolivre-rpa/.env
