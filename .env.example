# Environment Variables - AutoLinks
# Copie para .private/env/.env.local (git-ignored) e preencha os valores reais.
# Compatibilidade: .env.local na raiz ainda funciona, mas o recomendado e usar .private/env/.

# ─── API self-hosted (obrigatório) ───────────────────────────────────────────
# Local dev: aponte para o serviço API Node.js
# Coolify/docker-compose: se o frontend for servido pelo mesmo compose, deixe em branco e use o proxy do Nginx,
#   ou coloque a URL pública do serviço api (ex.: https://api.seudominio.com)
VITE_API_URL=http://127.0.0.1:3116
APP_PUBLIC_URL=http://127.0.0.1:5173
API_PUBLIC_URL=http://127.0.0.1:3116
# Produção: domínio frontend autorizado no CORS da API.
CORS_ORIGIN=http://127.0.0.1:5173
# Produção: origem(ns) da extensão autorizadas no CORS da API.
# Exemplo: chrome-extension://abcdefghijklmnopqrstuvwxyzabcdef
ALLOWED_EXTENSION_ORIGINS=
# Runtime de automações no navegador: mantenha desligado em produção quando o
# scheduler backend estiver ativo. Ative apenas como fallback controlado.
VITE_BROWSER_RUNTIME_ENABLED=false

# ─── Banco Supabase PostgreSQL (usado por local + deploy) ────────────────────
# Use a connection string direta do projeto Supabase.
# Exemplo: postgresql://postgres:[SUA-SENHA]@db.<project-ref>.supabase.co:5432/postgres
DATABASE_URL=postgresql://postgres:[SUA-SENHA]@db.rwurwyuhxvlnykosfkdj.supabase.co:5432/postgres
DB_SSL=true
DB_SSL_REJECT_UNAUTHORIZED=true

# NOTA: O frontend NÃO usa Supabase JS SDK nem a anon key.
# Todo acesso ao banco passa pelo API proxy (VITE_API_URL) com autenticação JWT + HttpOnly cookie.
# Não exponha VITE_SUPABASE_URL ou VITE_SUPABASE_PUBLISHABLE_DEFAULT_KEY aqui.

# ─── JWT e tokens de serviço (usados pelo serviço api) ───────────────────────
# JWT_SECRET deve ter pelo menos 32 caracteres aleatórios (OBRIGATÓRIO em produção)
JWT_SECRET=troque-por-segredo-jwt-com-32-caracteres-minimo
# JWT_EXPIRES_IN controla o tempo de vida do token (default: 2h)
JWT_EXPIRES_IN=2h
# SERVICE_TOKEN é usado pelo scheduler para autenticar como serviço (sem usuário)
SERVICE_TOKEN=troque-por-token-do-scheduler
# WEBHOOK_SECRET é usado para health/control entre API, Ops e microserviços.
# Em dev local, mantenha fixo para evitar desencontro entre processos em restart.
WEBHOOK_SECRET=autolinks-preview-webhook-local
# OPS_CONTROL_TOKEN protege endpoints do Ops Control e chamadas administrativas.
# Em dev local, mantenha fixo para evitar 401 no painel admin.
OPS_CONTROL_TOKEN=autolinks-preview-ops-token-local
# RPC público: mantenha false para exigir sessão em /hub/:slug e /mg/:id.
# Ative true apenas se você precisa deliberadamente de páginas públicas anônimas.
ALLOW_PUBLIC_RPC=false
# CREDENTIAL_ENCRYPTION_KEY: chave AES-256 para criptografar secrets no banco (OBRIGATÓRIO em produção)
# Gere com: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
CREDENTIAL_ENCRYPTION_KEY=troque-por-chave-hex-64-caracteres

# SESSION_ENCRYPTION_KEY: chave AES-256 para criptografar arquivos de sessão em disco (OBRIGATÓRIO)
# Usada pelos microserviços WhatsApp, Telegram e Meli. Domínio separado do banco.
# Gere com: openssl rand -hex 32
SESSION_ENCRYPTION_KEY=troque-por-chave-hex-64-caracteres

# SESSION_CIPHER_SALT: salt HKDF para derivação da chave de sessão (OBRIGATÓRIO em produção)
# Deve ser persistido entre redeploys — se mudar, todas as sessões existentes são irrecuperáveis.
# Gere com: openssl rand -hex 32
SESSION_CIPHER_SALT=troque-por-salt-hex-64-caracteres

# LOG_HASH_SALT: salt para hashes de user_id nos logs (OBRIGATÓRIO em produção)
# Sem um valor único, qualquer pessoa pode pré-computar o mapa hash→userId.
# Gere com: openssl rand -hex 32
LOG_HASH_SALT=troque-por-salt-unico-hex-32-chars

# ─── E-mail transacional (Resend) ────────────────────────────────────────────
RESEND_API_KEY=troque-por-chave-re_xxxxxxxxx
RESEND_FROM=Auto Links <suporte@autolinks.pro>
# Opcional (respostas para outro e-mail):
RESEND_REPLY_TO=suporte@autolinks.pro
EMAIL_VERIFY_TOKEN_TTL_MINUTES=1440
PASSWORD_RESET_TOKEN_TTL_MINUTES=30

# ─── CTA IA (OpenRouter) ───────────────────────────────────────────────────
# Chave da API OpenRouter usada para gerar o placeholder {cta_gerada_por_ia}.
OPENROUTER_API_KEY=troque-por-chave-openrouter
# Modelo padrao solicitado para CTA IA.
OPENROUTER_MODEL=openai/gpt-oss-20b
# Timeout de cada chamada (ms) e retries para erros transientes.
OPENROUTER_TIMEOUT_MS=12000
OPENROUTER_MAX_RETRIES=1
# Headers opcionais recomendados pelo OpenRouter para rastreio da aplicacao.
OPENROUTER_HTTP_REFERER=http://127.0.0.1:5173
OPENROUTER_APP_TITLE=AutoLinks CTA IA

# ─── Microserviços ────────────────────────────────────────────────────────────
# Local: use 127.0.0.1 | Coolify: use os nomes dos serviços do docker-compose
VITE_WHATSAPP_MICROSERVICE_URL=http://127.0.0.1:3111
VITE_TELEGRAM_MICROSERVICE_URL=http://127.0.0.1:3112
VITE_SHOPEE_MICROSERVICE_URL=http://127.0.0.1:3113
VITE_MELI_RPA_URL=http://127.0.0.1:3114
VITE_AMAZON_MICROSERVICE_URL=http://127.0.0.1:3117
VITE_OPS_CONTROL_URL=http://127.0.0.1:3115
OPS_CONTROL_URL=http://127.0.0.1:3115
SCHEDULER_RPC_BASE_URL=http://127.0.0.1:3116
SCHEDULER_RPC_TOKEN=autolinks-preview-service-token-local
MELI_AUTOMATION_INTERVAL_SECONDS=60
BACKUP_ENCRYPTION_KEY=troque-por-chave-forte-backup

AMAZON_MICROSERVICE_URL=http://127.0.0.1:3117
AMAZON_HEALTH_URL=http://127.0.0.1:3117/health

# Opcional em desenvolvimento local (se usar token no Ops Control):
# VITE_OPS_CONTROL_TOKEN=dev-ops-token

# ─── Runtime local (controles do sistema) ────────────────────────────────────
# Garante que o stack local mantenha o mesmo comportamento do deploy.
PREVIEW_ALLOW_PARTIAL_SERVICES=0
PREVIEW_DISABLE_SCHEDULER=0

# =========================
# CONTAS SEED
# Admin criado no primeiro boot da API (banco vazio).
# ADMIN_EMAIL e ADMIN_PASSWORD são obrigatórios em produção.
# Em dev, fallback: admin@localhost.local / senha gerada aleatoriamente.
# =========================
DISABLE_SIGNUP=true
ADMIN_EMAIL=admin@seudominio.com
ADMIN_PASSWORD=troque-esta-senha-segura
# VITE_DEMO_ADMIN_EMAIL=admin@demo.autolinks.local
# VITE_DEMO_ADMIN_PASSWORD=demo-admin-change-me
# VITE_DEMO_USER_EMAIL=usuario@demo.autolinks.local
# VITE_DEMO_USER_PASSWORD=demo-user-change-me

# Segredos e credenciais sensiveis devem ser configurados apenas nos servicos:
# - services/whatsapp-baileys/.env
# - services/telegram-telegraph/.env
# - services/shopee-affiliate/.env
# - services/mercadolivre-rpa/.env
# - services/amazon-affiliate/.env
