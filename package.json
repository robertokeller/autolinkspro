{
  "name": "auto-links",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "node scripts/dev.mjs",
    "dev:runtime": "concurrently -k -n OPS,API,SCHED,WEB -c cyan,blue,magenta,green --restart-tries 50 --restart-after 2000 \"npm run svc:ops:dev\" \"npm run svc:api:dev\" \"npm run scheduler:local\" \"vite --strictPort --port 5173 --host 127.0.0.1\"",
    "dev:runtime:attach": "concurrently -k -n SCHED,WEB -c magenta,green --restart-tries 50 --restart-after 2000 \"npm run scheduler:local\" \"vite --strictPort --port 5173 --host 127.0.0.1\"",
    "dev:runtime:degraded": "concurrently -k -n OPS,WEB -c cyan,green --restart-tries 50 --restart-after 2000 \"npm run svc:ops:dev\" \"vite --strictPort --port 5173 --host 127.0.0.1\"",
    "dev:web": "vite --strictPort --port 5173 --host 127.0.0.1",
    "db:dev": "echo \"Using shared Supabase database (no local Postgres container).\"",
    "db:dev:stop": "echo \"No local database container to stop.\"",
    "resync:dev": "npm run db:migrate:dev && npm run seed:dev",
    "db:migrate:dev": "node scripts/migrate-dev.mjs",
    "seed:dev": "node scripts/seed-users.mjs",
    "supabase:init": "supabase init --force --yes",
    "supabase:link": "supabase link --project-ref rwurwyuhxvlnykosfkdj --yes",
    "supabase:db:push": "supabase db push",
    "db:migrate:supabase": "npm run supabase:db:push",
    "preview:local": "node scripts/preview-ready.mjs --host 127.0.0.1 --port 5173",
    "preview:live": "node scripts/preview-ready.mjs --host 0.0.0.0 --port 5173",
    "preview:safe": "node scripts/preview-safe.mjs",
    "preview:ready": "node scripts/preview-ready.mjs",
    "build": "vite build",
    "build:dev": "vite build --mode development",
    "start": "node scripts/serve-dist.mjs",
    "scheduler:start": "node scripts/dispatch-scheduler.mjs",
    "scheduler:local": "node scripts/scheduler-local.mjs",
    "lint": "eslint .",
    "preview": "node scripts/preview-ready.mjs",
    "preview:dist": "vite preview",
    "ext:icons:build": "node scripts/generate-extension-icons.mjs",
    "test": "vitest run",
    "test:watch": "vitest",
    "svc:wa:build": "npm --prefix services/whatsapp-baileys run build",
    "svc:wa:start": "npm --prefix services/whatsapp-baileys run start",
    "svc:wa:dev": "powershell -NoProfile -ExecutionPolicy Bypass -Command \"$env:ALLOW_INSECURE_NO_SECRET='true'; npm --prefix services/whatsapp-baileys run dev\"",
    "svc:tg:build": "npm --prefix services/telegram-telegraph run build",
    "svc:tg:start": "npm --prefix services/telegram-telegraph run start",
    "svc:tg:dev": "powershell -NoProfile -ExecutionPolicy Bypass -Command \"$env:ALLOW_INSECURE_NO_SECRET='true'; npm --prefix services/telegram-telegraph run dev\"",
    "svc:shopee:build": "npm --prefix services/shopee-affiliate run build",
    "svc:shopee:start": "npm --prefix services/shopee-affiliate run start",
    "svc:shopee:dev": "powershell -NoProfile -ExecutionPolicy Bypass -Command \"$env:ALLOW_INSECURE_NO_SECRET='true'; npm --prefix services/shopee-affiliate run dev\"",
    "svc:meli:build": "npm --prefix services/mercadolivre-rpa run build",
    "svc:meli:start": "npm --prefix services/mercadolivre-rpa run start",
    "svc:meli:dev": "powershell -NoProfile -ExecutionPolicy Bypass -Command \"$env:ALLOW_INSECURE_NO_SECRET='true'; npm --prefix services/mercadolivre-rpa run dev\"",
    "svc:meli:install": "npm --prefix services/mercadolivre-rpa install",
    "svc:ops:start": "npm --prefix services/ops-control run start",
    "svc:ops:dev": "powershell -NoProfile -ExecutionPolicy Bypass -Command \"npm --prefix services/ops-control run dev\"",
    "system:bootstrap": "concurrently -k -n OPS,WEB -c cyan,green --restart-tries 50 --restart-after 2000 \"npm run svc:ops:dev\" \"npm run preview:safe\"",
    "svc:api:build": "npm --prefix services/api run build",
    "svc:api:start": "npm --prefix services/api run start",
    "svc:api:dev": "powershell -NoProfile -ExecutionPolicy Bypass -Command \"if (-not $env:JWT_SECRET) { $env:JWT_SECRET='dev-jwt-secret-local-only-32chars!!' }; if (-not $env:SERVICE_TOKEN) { $env:SERVICE_TOKEN='dev-service-token-local-only' }; if (-not $env:WEBHOOK_SECRET) { $env:WEBHOOK_SECRET='preview-local-dev-secret' }; if (-not $env:CORS_ORIGIN) { $env:CORS_ORIGIN='*' }; if (-not $env:OPS_CONTROL_URL) { $env:OPS_CONTROL_URL='http://127.0.0.1:3115' }; if (-not $env:ADMIN_EMAIL) { $env:ADMIN_EMAIL='admin@local.autolinks' }; if (-not $env:ADMIN_PASSWORD) { $env:ADMIN_PASSWORD='dev-admin-change-me' }; npm --prefix services/api run dev\"",
    "svc:all:build": "npm run svc:wa:build && npm run svc:tg:build && npm run svc:shopee:build && npm run svc:meli:build",
    "svc:all:start": "npm run svc:wa:start & npm run svc:tg:start & npm run svc:shopee:start & npm run svc:meli:start & npm run svc:ops:start",
    "prod:build": "npm run build && npm run svc:all:build",
    "pm2:start": "pm2 start ecosystem.config.cjs --env production",
    "pm2:restart": "pm2 restart ecosystem.config.cjs --update-env",
    "pm2:stop": "pm2 stop ecosystem.config.cjs",
    "pm2:delete": "pm2 delete ecosystem.config.cjs",
    "pm2:save": "pm2 save",
    "pm2:bootstrap": "npm run prod:build && npm run pm2:start && npm run pm2:save",
    "guardian:start": "node scripts/health-guardian.mjs",
    "monitor:channels": "node scripts/monitor-channel-flow.mjs",
    "monitor:routes": "node scripts/monitor-channel-flow.mjs --interval-ms 8000 --window-min 20 --issues-limit 5",
    "monitor:routes:once": "node scripts/monitor-channel-flow.mjs --interval-ms 8000 --window-min 20 --issues-limit 5 --ticks 1",
    "monitor:routes:alerts": "node scripts/monitor-channel-flow.mjs --interval-ms 5000 --window-min 20 --issues-limit 5 --only-issues",
    "monitor:routes:failfast": "node scripts/monitor-channel-flow.mjs --interval-ms 5000 --window-min 20 --issues-limit 5 --only-issues --exit-on-issue",
    "deploy:preflight": "node scripts/preflight-coolify.mjs",
    "smoke:coolify": "node scripts/smoke-coolify.mjs",
    "ops:verify:global-controls": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/verify-ops-global-controls.ps1"
  },
  "dependencies": {
    "@radix-ui/react-accordion": "^1.2.11",
    "@radix-ui/react-alert-dialog": "^1.1.14",
    "@radix-ui/react-checkbox": "^1.3.2",
    "@radix-ui/react-collapsible": "^1.1.11",
    "@radix-ui/react-dialog": "^1.1.14",
    "@radix-ui/react-dropdown-menu": "^2.1.15",
    "@radix-ui/react-label": "^2.1.7",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-progress": "^1.1.7",
    "@radix-ui/react-scroll-area": "^1.2.9",
    "@radix-ui/react-select": "^2.2.5",
    "@radix-ui/react-separator": "^1.1.7",
    "@radix-ui/react-slider": "^1.3.5",
    "@radix-ui/react-slot": "^1.2.3",
    "@radix-ui/react-switch": "^1.2.5",
    "@radix-ui/react-tabs": "^1.1.12",
    "@radix-ui/react-tooltip": "^1.2.7",
    "@tanstack/react-query": "^5.83.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^3.6.0",
    "date-fns-tz": "^3.2.0",
    "framer-motion": "^12.34.0",
    "lucide-react": "^0.462.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.30.3",
    "recharts": "^2.15.4",
    "sonner": "^1.7.4",
    "tailwind-merge": "^2.6.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@eslint/js": "^9.32.0",
    "@testing-library/jest-dom": "^6.6.0",
    "@types/node": "^22.16.5",
    "@types/react": "^18.3.23",
    "@types/react-dom": "^18.3.7",
    "@vitejs/plugin-react-swc": "^3.11.0",
    "autoprefixer": "^10.4.21",
    "bcryptjs": "^3.0.3",
    "concurrently": "^9.2.1",
    "eslint": "^9.32.0",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.20",
    "globals": "^15.15.0",
    "jsdom": "^20.0.3",
    "pg": "^8.20.0",
    "postcss": "^8.5.6",
    "sharp": "^0.34.5",
    "tailwindcss": "^3.4.17",
    "tailwindcss-animate": "^1.0.7",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.38.0",
    "vite": "^5.4.19",
    "vitest": "^3.2.4"
  }
}
