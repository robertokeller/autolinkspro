{
  "manifest_version": 3,
  "name": "AutoLinks - Mercado Livre",
  "description": "Captura cookies do Mercado Livre e envia automaticamente para o Autolinks.",
  "version": "1.1.5",
  "permissions": ["cookies", "storage", "tabs"],
  "host_permissions": [
    "https://*.mercadolivre.com.br/*",
    "https://*.mercadolibre.com/*",
    "https://*.meli.la/*",
    "https://autolinks.pro/*",
    "https://www.autolinks.pro/*",
    "https://api.autolinks.pro/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "action": {
    "default_title": "AutoLinks - Mercado Livre",
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png",
      "48": "icons/icon-48.png"
    }
  },
  "content_security_policy": {
    "extension_pages": "default-src 'none'; script-src 'self'; style-src 'self'; img-src 'self' data:; connect-src https://api.autolinks.pro"
  },
  "content_scripts": [
    {
      "matches": [
        "https://autolinks.pro/*",
        "https://www.autolinks.pro/*"
      ],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
