# =========================
# BANCO DE DADOS PostgreSQL
# =========================
POSTGRES_DB=autolinks
POSTGRES_USER=autolinks
POSTGRES_PASSWORD=troque-por-senha-forte-aqui

# =========================
# JWT E TOKENS DE SERVIÇO
# =========================
# JWT_SECRET deve ter pelo menos 32 caracteres aleatórios
JWT_SECRET=troque-por-segredo-jwt-com-32-caracteres-minimo
# SERVICE_TOKEN é usado pelo scheduler para autenticar como serviço
SERVICE_TOKEN=troque-por-token-do-scheduler

# =========================
# ADMIN INICIAL (criado no primeiro boot se não houver usuários)
# =========================
ADMIN_EMAIL=admin@seudominio.com
ADMIN_PASSWORD=SuaSenhaAdmin2025!
# Desativa o endpoint público /auth/signup — use true em produção quando
# contas são criadas exclusivamente pelo painel admin. false = signup aberto.
DISABLE_SIGNUP=true

# =========================
# URL PÚBLICA DA API (usada pelo frontend no build)
# =========================
VITE_API_URL=https://api.seudominio.com

# =========================
# PUBLIC URLS (used at web build time)
# =========================
VITE_WHATSAPP_MICROSERVICE_URL=https://wa-api.seudominio.com
VITE_TELEGRAM_MICROSERVICE_URL=https://tg-api.seudominio.com
VITE_SHOPEE_MICROSERVICE_URL=https://shopee-api.seudominio.com
VITE_MELI_RPA_URL=https://meli-api.seudominio.com
VITE_OPS_CONTROL_URL=https://ops-api.seudominio.com
# VITE_WEBHOOK_SECRET foi removido: WEBHOOK_SECRET e um segredo de servidor
# e nunca deve ser exposto no bundle JS do frontend.

# =========================
# INTERNAL SERVICES
# =========================
WEBHOOK_SECRET=troque-esta-chave
OPS_CONTROL_TOKEN=troque-esta-chave
LOG_LEVEL=info

# Cookie cross-domain: necessário quando frontend (app.seudominio.com) e API
# (api.seudominio.com) usam subdomínios diferentes. Defina como ".seudominio.com"
# (com o ponto inicial). Deixe vazio para localhost/dev.
AUTH_COOKIE_DOMAIN=.seudominio.com

# Telegram API — obtenha em https://my.telegram.org/apps
TELEGRAM_API_ID=seu_api_id
TELEGRAM_API_HASH=seu_api_hash

# CORS: defina a URL do frontend para cada servico.
# Se nao definido, o servico so aceita requisicoes de localhost (seguranca por padrao).
CORS_ORIGIN=https://app.seudominio.com
MELI_CORS_ORIGIN=https://app.seudominio.com

# =========================
# SCHEDULER 24/7
# =========================
SCHEDULER_MODE=remote
# SCHEDULER_RPC_BASE_URL deve apontar para a URL pública da API (mesmo valor de VITE_API_URL)
SCHEDULER_RPC_BASE_URL=https://api.seudominio.com
# SCHEDULER_RPC_TOKEN usa o mesmo valor de SERVICE_TOKEN — token único consolidado
SCHEDULER_RPC_TOKEN=troque-por-token-do-scheduler
DISPATCH_INTERVAL_SECONDS=45
SHOPEE_INTERVAL_SECONDS=60
DISPATCH_LIMIT=100
DISPATCH_SOURCE=coolify-scheduler
SCHEDULER_TIMEOUT_MS=15000

# =========================
# SMOKE TEST PÓS-DEPLOY
# =========================
# Usado por: SERVICE_TOKEN=xxx SMOKE_API_URL=... npm run smoke:coolify
# SERVICE_TOKEN      → mesmo valor definido acima
# As variáveis SMOKE_* são usadas apenas localmente na máquina que roda o teste.
SMOKE_API_URL=https://api.seudominio.com
SMOKE_WA_URL=https://wa-api.seudominio.com
SMOKE_TG_URL=https://tg-api.seudominio.com
SMOKE_SHOPEE_URL=https://shopee-api.seudominio.com
SMOKE_MELI_URL=https://meli-api.seudominio.com
SMOKE_OPS_URL=https://ops-api.seudominio.com
SMOKE_WEB_URL=https://app.seudominio.com
SMOKE_WEBHOOK_SECRET=troque-esta-chave
SMOKE_OPS_TOKEN=troque-esta-chave
