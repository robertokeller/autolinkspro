# =========================
# Auto Links - Coolify env
# =========================

# --- Banco ---
POSTGRES_DB=autolinks
POSTGRES_USER=autolinks
POSTGRES_PASSWORD=troque-por-senha-forte
APPLY_SEED_MIGRATIONS=false

# --- Seguranca ---
JWT_SECRET=troque-por-um-segredo-com-32-caracteres-ou-mais
JWT_EXPIRES_IN=2h
SERVICE_TOKEN=troque-por-token-forte-de-servico
WEBHOOK_SECRET=troque-por-webhook-secret-forte
OPS_CONTROL_TOKEN=troque-por-ops-token-forte
# Gere com: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
CREDENTIAL_ENCRYPTION_KEY=troque-por-chave-hex-64-caracteres

# --- Dominios ---
APP_PUBLIC_URL=https://autolinks.pro
API_PUBLIC_URL=https://api.autolinks.pro
CORS_ORIGIN=https://autolinks.pro
AUTH_COOKIE_DOMAIN=.autolinks.pro

# --- Cadastro / admin ---
DISABLE_SIGNUP=true
ADMIN_EMAIL=suporte@autolinks.pro
ADMIN_PASSWORD=troque-por-uma-senha-forte

# --- Resend (verificacao de conta + reset de senha) ---
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxx
RESEND_FROM=Auto Links <suporte@autolinks.pro>
RESEND_REPLY_TO=suporte@autolinks.pro
EMAIL_VERIFY_TOKEN_TTL_MINUTES=1440
PASSWORD_RESET_TOKEN_TTL_MINUTES=30

# --- URLs publicas usadas no build do frontend ---
VITE_API_URL=https://api.autolinks.pro
VITE_WHATSAPP_MICROSERVICE_URL=https://wa-api.autolinks.pro
VITE_TELEGRAM_MICROSERVICE_URL=https://tg-api.autolinks.pro
VITE_SHOPEE_MICROSERVICE_URL=https://shopee-api.autolinks.pro
VITE_MELI_RPA_URL=https://meli-api.autolinks.pro
VITE_OPS_CONTROL_URL=https://ops-api.autolinks.pro

# --- Telegram ---
TELEGRAM_API_ID=123456
TELEGRAM_API_HASH=troque-por-telegram-api-hash

# --- Mercado Livre ---
MELI_CORS_ORIGIN=https://autolinks.pro

# --- Scheduler 24/7 ---
SCHEDULER_MODE=remote
SCHEDULER_RPC_BASE_URL=https://api.autolinks.pro
# O token do scheduler e herdado de SERVICE_TOKEN no docker-compose.coolify.yml
DISPATCH_INTERVAL_SECONDS=15
SHOPEE_INTERVAL_SECONDS=60
CHANNEL_EVENTS_INTERVAL_SECONDS=15
DISPATCH_LIMIT=25
DISPATCH_SOURCE=scheduler
SCHEDULER_TIMEOUT_MS=20000

# --- Operacao / logs ---
LOG_LEVEL=info
# Debug temporario de captura de midia (texto+imagem) em API + conectores.
ROUTE_MEDIA_DEBUG=false
# Opcional: override explicito nos conectores (se vazio, herda ROUTE_MEDIA_DEBUG).
MEDIA_CAPTURE_DEBUG=false

# --- Backup ---
BACKUP_SCHEDULE=0 3 * * *
BACKUP_KEEP_DAYS=7
SESSIONS_BACKUP_SCHEDULE=0 4 * * *
SESSIONS_BACKUP_KEEP_DAYS=7
